{
  "name": "react-cra-demo",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@norejs/prefetch": "workspace:*",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "integrate-prefetch": "prefetch integrate --input public/service-worker.js --output public/service-worker-integrated.js",
    "create-sw": "prefetch integrate --create --output public/service-worker.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}

