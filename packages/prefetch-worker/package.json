{
  "name": "@norejs/prefetch-worker",
  "version": "1.0.0",
  "description": "Service worker implementation for background prefetching with ESM and UMD support",
  "type": "module",
  "main": "dist/service-worker.js",
  "module": "dist/service-worker.esm.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/service-worker.esm.js",
      "require": "./dist/prefetch-worker.umd.js",
      "types": "./dist/types/index.d.ts"
    },
    "./umd": "./dist/prefetch-worker.umd.js",
    "./esm": "./dist/service-worker.esm.js",
    "./iife": "./dist/service-worker.js"
  },
  "files": [
    "dist",
    "src",
    "templates",
    "docs",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "npm run clean && rollup -c",
    "build:dev": "cross-env NODE_ENV=development rollup -c",
    "build:prod": "cross-env NODE_ENV=production rollup -c",
    "build:watch": "rollup -c --watch",
    "dev": "npm run build:dev && npm run dev:server",
    "dev:server": "serve dist --listen 18003 --cors --single",
    "clean": "rimraf dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.js",
    "lint:fix": "eslint src --ext .ts,.js --fix",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prepublishOnly": "npm run build:prod",
    "copy-template": "cp templates/service-worker.js ../../service-worker.js && echo 'ESM template copied to project root'",
    "copy-template:here": "cp templates/service-worker.js ./service-worker.js && echo 'ESM template copied to current directory'"
  },
  "keywords": [
    "service-worker",
    "prefetch",
    "cache",
    "pwa",
    "esm",
    "umd",
    "background",
    "performance"
  ],
  "author": "NoReJS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/norejs/prefetch.git",
    "directory": "packages/prefetch-worker"
  },
  "bugs": {
    "url": "https://github.com/norejs/prefetch/issues"
  },
  "homepage": "https://github.com/norejs/prefetch#readme",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^5.0.5",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "rimraf": "^5.0.5",
    "rollup": "^4.9.1",
    "serve": "^14.2.5",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "dependencies": {
    "crypto-js": "^4.2.0"
  },
  "peerDependencies": {
    "@norejs/prefetch": "*"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "browserslist": [
    "Chrome >= 91",
    "Firefox >= 89",
    "Safari >= 15",
    "Edge >= 91"
  ]
}